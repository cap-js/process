{
  "name": "bookshop",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/process": "file:../../"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "tsx": "^4",
    "@cap-js/cds-types": "^0.15.0",
    "@types/node": "^24.0.0",
    "typescript": "^5",
    "@cap-js/cds-typer": ">=0.1"
  },
  "scripts": {
    "start": "cds-serve",
    "build": "npm run cds-build && npm run cds-typer",
    "cds-build": "cds-tsx build",
    "cds-typer": "npx @cap-js/cds-typer \"*\" --outputDirectory @cds-models"
  },
  "private": true,
  "cds": {
    "requires": {
      "db-ext": {
        "[development]": {
          "model": "db/sqlite"
        },
        "[production]": {
          "model": "db/hana"
        }
      }
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}
