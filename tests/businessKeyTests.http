@server = http://localhost:4004

# @name create car entity
POST {{server}}/odata/v4/businesskey/Car
Content-Type: application/json

{
    "ID": "1234",
    "mileage": 10000
}

###

# @name create dog entity
POST {{server}}/odata/v4/businesskey/Dog
Content-Type: application/json

{
    "ID": "1234",
    "name": "Alex"
}

###

# @name update dog entity
PATCH {{server}}/odata/v4/businesskey/Dog('1234')
Content-Type: application/json

{
    "name": "Tim"
}

###

