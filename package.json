{
  "name": "@cap-js/process",
  "version": "1.0.0",
  "description": "",
  "main": "cds-plugin.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest tests/integration",
    "build": "npm run cds-build && npm run cds-typer",
    "cds-build": "cds-tsx build",
    "cds-typer": "npx @cap-js/cds-typer \"*\" --outputDirectory @cds-models",
    "watch": "cds-tsx watch",
    "process:import": "cds bind --exec -- cds-tsx import --from process --no-save --as cds"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "peerDependencies": {
    "@sap/cds": ">=9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "workspaces": [
    "tests/bookshop"
  ],
  "dependencies": {
    "@cap-js/cds-typer": "^0.38.0",
    "@sap-cloud-sdk/connectivity": "^4.1.2",
    "@sap-cloud-sdk/http-client": "^4.1.2",
    "@sap-cloud-sdk/resilience": "^4.1.2",
    "@types/node": "^25.0.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "cds": {
    "requires": {
      "ProcessService": {
        "[development]": {
          "kind": "local-process-service"
        },
        "[production]": {
          "kind": "deployed-process-service"
        }
      },
      "kinds": {
        "local-process-service": {
          "model": "@cap-js/process/srv/localProcessService"
        },
        "deployed-process-service": {
          "model": "@cap-js/process/srv/BTPProcessService"
        }
      },
      "Workflow": {
        "kind": "service",
        "model": "srv/external/SPA_Workflow_Runtime"
      }
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  }
}