{
  "name": "process",
  "version": "1.0.0",
  "description": "",
  "main": "cds-plugin.ts", 
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run gen-workflow && npm run cds-build && npm run cds-typer",
    "gen-workflow": "npx @sap-cloud-sdk/openapi-generator -i specs/workflow.json -o clients --overwrite",
    "cds-build": "cds-tsx build",
    "cds-typer": "npx @cap-js/cds-typer \"*\" --outputDirectory @cds-models",
    "watch": "cds-tsx watch",
    "process:import": "cds bind --exec -- cds-tsx import --from process --no-save --as cds"
  },

  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "peerDependencies": {
    "@sap/cds": ">=9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "tests/bookshop"
  ],
  "dependencies": {
    "@sap-cloud-sdk/openapi": "^4.1.2",
    "@types/node": "^25.0.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "@cap-js/cds-typer": "^0.38.0"
  }
}
